# ===================================
# DEVELOPMENT ENVIRONMENT
# ===================================

BASE_URL=https://ecommerce-playground.lambdatest.io
ENVIRONMENT=dev
HEADLESS=false
BROWSER=chromium

# Test credentials (if needed in future)
TEST_USERNAME=dev_user@example.com
TEST_PASSWORD=dev_password

# Search test data
SEARCH_VALID_KEYWORD=Macbook
SEARCH_INVALID_KEYWORD=#$@%&
SEARCH_MIN_KEYWORD=a
SEARCH_AUTOCOMPLETE_KEYWORD=mac
SEARCH_MAX_LENGTH=250

# Timeouts (ms)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
EXPECT_TIMEOUT=15000

# Retries
RETRY_COUNT=1
